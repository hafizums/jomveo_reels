WAVESPEED_API_KEY=your_wavespeed_api_key_here

# Optional application settings
APP_NAME="JomVeo Reels API"
APP_ENV=development
DEBUG=false
API_V1_PREFIX=/api
WAVESPEED_LLM_BASE_URL=https://llm.wavespeed.ai/v1
WAVESPEED_API_BASE_URL=https://api.wavespeed.ai/api/v3
CORS_ALLOWED_ORIGINS='["http://localhost:5173","http://127.0.0.1:5173"]'
GENERATED_ROOT=generated
DATABASE_URL=sqlite:///backend/generated/jomveo.db
QUEUE_BACKEND=inline
REDIS_URL=redis://localhost:6379/0
JOB_DEFAULT_TIMEOUT_SECONDS=1800
JOB_MAX_ATTEMPTS=3
JOB_RETRY_BACKOFF_SECONDS=30
JOB_STALE_AFTER_SECONDS=900
JOB_WORKER_ID=local-worker
LOG_LEVEL=INFO
REQUEST_ID_HEADER=X-Request-ID
